generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  TOUR_GUIDE
  ADMIN
}

enum Category {
  ADVENTURE
  CULTURAL
  BEACH
  WILDLIFE
  HISTORICAL
  RELIGIOUS
  NATURE
  FOOD_AND_CUISINE
  CITY_TOUR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  bookings            Booking[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  reviews             Review[]
}

model Destination {
  id          String   @id @default(uuid())
  title       String
  description String
  country     String
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  excursions Excursion[]
}

model Excursion {
  id            String   @id @default(uuid())
  destinationId String
  title         String
  description   String
  category      Category
  images        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id])
  packages    Package[]
}

model Package {
  id             String   @id @default(uuid())
  excursionId    String
  title          String
  price          Float
  duration       String
  schedule       String
  availableSeats Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  excursion Excursion @relation(fields: [excursionId], references: [id])
  bookings  Booking[]
}

model Booking {
  id           String        @id @default(uuid())
  userId       String
  packageId    String
  participants Int
  totalPrice   Float
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())

  user    User    @relation(fields: [userId], references: [id])
  package Package @relation(fields: [packageId], references: [id])
  review  Review?
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  bookingId String   @unique
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}